#!/usr/bin/env bash
set -euo pipefail

UNICODE_EMOJI_LIST="$HOME/.local/share/unicode-emoji-data-cut.txt"

foreground_color=$(_system_color CF_WHITE_BR)
background_color=$(_system_color C0_BLACK)

choice=$(cat ${UNICODE_EMOJI_LIST} | \
        wmenu \
        -N $background_color -n $foreground_color \
        -M $background_color -m $foreground_color \
        -S $foreground_color -s $background_color \
        -i \
        -p "unicode:" \
        -f "IBM Plex Mono 13") # TODO: use $FONT

if [ -n "$choice" ]; then
    symbol=$(echo "$choice" | awk '{print $1}')
    printf "%s" "$symbol" | wl-copy
fi
