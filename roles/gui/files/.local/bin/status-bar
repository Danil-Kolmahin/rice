#!/usr/bin/env bash
set -euo pipefail

# TODO: rewrite

reboot-needed-status() {
    vercmp $(pacman -Q linux | cut -d " " -f 2) $(uname -r)
}

mic-active() {
    if fuser /dev/snd/pcmC*c 2>/dev/null | grep -q .; then
        echo "MIC"
    fi

    # # TODO: fix fn+F9 (probably emulation thing)
    # mute=$(pactl get-source-mute @DEFAULT_SOURCE@ | awk '{print $2}')
    # if [ "$mute" = "yes" ]; then echo "MUTE"; fi
    # # STATUS+="{\"full_text\":\"MIC:$(mic-status)\"},"
}

cam-active() {
    for dev in /dev/video*; do
        if fuser "$dev" 2>/dev/null | grep -q .; then
            echo "CAM"
            return
        fi
    done
}

rec-active() {
    if pw-dump 2>/dev/null | jq -e '
        .[] | select(
            .info.props["media.class"] == "Video/Source" and
            (.info.state? == "running")
        )' > /dev/null 2>&1; then
        echo "REC"
    fi
    pgrep -x "wf-recorder|obs|gpu-screen-recorder|kooha" > /dev/null && echo "REC"
}

vpn-status() {
    local iface
    local routes
    local vpn_re='(tun|tap|wg|wireguard|vpn|ovpn|openvpn|tailscale|nordlynx|zerotier|^zt|ipsec|xfrm|vti|ppp|warp|nebula|ham|anyconnect|cisco|forti|globalprotect|pulse|proton|mullvad|surfshark|expressvpn|ivpn|windscribe)'

    while IFS= read -r iface; do
        routes=$'\n'
        routes+="$({ ip -4 route show table all dev "$iface"; ip -6 route show table all dev "$iface"; } 2>/dev/null || true)"
        routes+=$'\n'

        if [[ $routes == *$'\ndefault '* ]] \
            || [[ $routes == *$'\n0.0.0.0/1 '* && $routes == *$'\n128.0.0.0/1 '* ]] \
            || [[ $routes == *$'\n::/1 '* && $routes == *$'\n8000::/1 '* ]]; then
            STATUS+="{\"full_text\":\"FVPN:$iface\",\"color\":\"#000000\",\"background\":\"#ffff00\",\"border\":\"#00000000\"},"
        else
            STATUS+="{\"full_text\":\"SVPN:$iface\",\"color\":\"#000000\",\"background\":\"#ffff00\",\"border\":\"#00000000\"},"
        fi
    done < <(ip -o link show up | awk -F': ' -v vpn_re="$vpn_re" '{
        split($2, name, "@")
        if (tolower(name[1]) ~ vpn_re) print name[1]
    }')
}

net-status() {
    # TODO: check connection
    local links
    local new_net_rx
    local new_net_tx
    local net_rx_delta
    local net_tx_delta
    local vpn_re='(tun|tap|wg|wireguard|vpn|ovpn|openvpn|tailscale|nordlynx|zerotier|^zt|ipsec|xfrm|vti|ppp|warp|nebula|ham|anyconnect|cisco|forti|globalprotect|pulse|proton|mullvad|surfshark|expressvpn|ivpn|windscribe)'

    links="$(ip -o link show up | awk -F': ' -v vpn_re="$vpn_re" '$0 ~ /<[^>]*LOWER_UP/ {
        split($2, name, "@")
        if (name[1] != "lo" && tolower(name[1]) !~ vpn_re) print name[1]
    }')"

    read -r new_net_rx new_net_tx < <(awk -v links="$links" '
        BEGIN {
            split(links, link, "\n")
            for (i in link) if (link[i] != "") passthrough[link[i]] = 1
        }
        {
            iface = $1
            sub(/:$/, "", iface)
            if (iface in passthrough) {
                rx += $2
                tx += $10
            }
        }
        END { printf "%.0f %.0f\n", rx, tx }
    ' /proc/net/dev)

    if [ -z "${net_rx:-}" ] || [ -z "${net_tx:-}" ]; then
        net_rx="$new_net_rx"
        net_tx="$new_net_tx"
    fi

    net_rx_delta=$((new_net_rx >= net_rx ? new_net_rx - net_rx : 0))
    net_tx_delta=$((new_net_tx >= net_tx ? new_net_tx - net_tx : 0))
    net_rx="$new_net_rx"
    net_tx="$new_net_tx"

    STATUS+="{\"full_text\":\"NET:↓$(numfmt --to=iec --suffix=B "$net_rx_delta"),↑$(numfmt --to=iec --suffix=B "$net_tx_delta")\"},"
}

psi-io-status() {
    awk '/some/ {split($2,arr,"="); printf("%d%%\n",arr[2])}' /proc/pressure/io
}

psi-ram-status() {
    awk '/some/ {split($2,arr,"="); printf("%d%%\n",arr[2])}' /proc/pressure/memory
}

psi-cpu-status() {
    awk '/some/ {split($2,arr,"="); printf("%d%%\n",arr[2])}' /proc/pressure/cpu
}

load-status() {
    awk '{print $1}' /proc/loadavg
}

disk-status() {
    df -h / | awk 'NR == 2 {print $(NF-1)}'
}

ram-status() {
    awk '/MemTotal/ {mt=$2} /MemAvailable/ {ma=$2} END {printf("%.f%%\n", 100*(mt-ma)/mt)}' /proc/meminfo
}

# TODO: refactor, rename, test
workJiffies1=0
totalJiffies1=0
cpu-status() {
    read -r sb_cs_0 sb_cs_user sb_cs_nice sb_cs_system sb_cs_idle sb_cs_iowait sb_cs_irq sb_cs_softirq sb_cs_0 < /proc/stat

    workJiffies2=$((sb_cs_user + sb_cs_nice + sb_cs_system))
    totalJiffies2=$((workJiffies2 + sb_cs_idle + sb_cs_iowait + sb_cs_irq + sb_cs_softirq))

    workDiff=$((workJiffies2 - workJiffies1))
    totalDiff=$((totalJiffies2 - totalJiffies1))

    workJiffies1=$workJiffies2
    totalJiffies1=$totalJiffies2

    echo $((100 * $workDiff / $totalDiff))
}

power-status() {
    local percentage
    local power
    local time_to_empty
    local time_to_full
    percentage=$(upower -b | awk '/percentage/ {print $2}')
    power=$(upower -b | awk '/energy-rate/ {printf "%.1fW\n", $2}')
    case $(upower -b | awk '/state/ {print $2}') in
        discharging)
            time_to_empty=$(upower -b | grep "time to empty" | awk '{print $4 " " $5}')
            echo "$percentage(-$power, $time_to_empty)"
            ;;
        charging)
            time_to_full=$(upower -b | grep "time to full" | awk '{print $4 " " $5}')
            echo "$percentage(+$power, $time_to_full)"
            ;;
        fully-charged)
            echo "$percentage"
            ;;
    esac
}

power-profile() {
    case $(tlpctl get) in
        performance) echo "AC" ;;
        balanced) echo "BAT" ;;
        power-saver) echo "SAV" ;;
    esac
}

brightness-level() {
    brightnessctl i -m | awk -F',' '{print $4}' | sed 's/.$//'
}

volume-status() {
    volume=$(pactl get-sink-volume @DEFAULT_SINK@ | awk '{print $5}')
    mute=$(pactl get-sink-mute @DEFAULT_SINK@ | awk '{print $2}')
    if [ "$mute" = "yes" ]; then
        echo "MUTE"
    else
        echo "$volume"
    fi
}

keyboard-layout() {
    # TODO improve to take original lang name, use xkb
    swaymsg -t get_inputs | jq 'map(select(has("xkb_active_layout_name")))[0].xkb_active_layout_name' | sed 's/.*/\L&/' | cut -c2-3
}

datetime-status() {
    date +'%Y-%m-%d %X'
}

echo '{"version":1}'
echo '['

while true; do
    STATUS=""

    [[ $(reboot-needed-status) -gt 0 ]] && STATUS+="{\"full_text\":\"REBOOT REQUIRED\",\"color\":\"#000000\",\"background\":\"#ff0000\",\"border\":\"#00000000\"},"
    # STATUS+="{\"full_text\":\"BT:on(1)\"},"

    [ -n "$(mic-active)" ] && STATUS+="{\"full_text\":\"MIC\",\"color\":\"#000000\",\"background\":\"#ff0000\",\"border\":\"#00000000\"},"
    [ -n "$(cam-active)" ] && STATUS+="{\"full_text\":\"CAM\",\"color\":\"#000000\",\"background\":\"#ff0000\",\"border\":\"#00000000\"},"
    [ -n "$(rec-active)" ] && STATUS+="{\"full_text\":\"REC\",\"color\":\"#000000\",\"background\":\"#ff0000\",\"border\":\"#00000000\"},"
    
    vpn-status
    net-status

    STATUS+="{\"full_text\":\"PSI:io$(psi-io-status),ram$(psi-ram-status),cpu$(psi-cpu-status)\"},"

    disk_pct=$(df / | awk 'NR == 2 {gsub(/%/,"",$5); print $5}') # TODO: unify
    if [ "$disk_pct" -ge 90 ]; then
        STATUS+="{\"full_text\":\"DISK:$(disk-status)\",\"color\":\"#000000\",\"background\":\"#ff0000\",\"border\":\"#00000000\"},"
    elif [ "$disk_pct" -ge 75 ]; then
        STATUS+="{\"full_text\":\"DISK:$(disk-status)\",\"color\":\"#000000\",\"background\":\"#ffff00\",\"border\":\"#00000000\"},"
    else
        STATUS+="{\"full_text\":\"DISK:$(disk-status)\"},"
    fi

    STATUS+="{\"full_text\":\"RAM:$(ram-status)\"},"
    STATUS+="{\"full_text\":\"CPU:$(cpu-status)%\"}," # TODO: add ,73°C
    if [ $(upower -b | awk '/state/ {print $2}') = "discharging" ]; then
        STATUS+="{\"full_text\":\"$(power-profile):$(power-status)\",\"color\":\"#000000\",\"background\":\"#ff0000\",\"border\":\"#00000000\"},"
    else
        STATUS+="{\"full_text\":\"$(power-profile):$(power-status)\"},"
    fi
    STATUS+="{\"full_text\":\"BRT:$(brightness-level)%\"},"
    STATUS+="{\"full_text\":\"VOL:$(volume-status)\"},"
    STATUS+="{\"full_text\":\"$(keyboard-layout)\"},"
    STATUS+="{\"full_text\":\"$(datetime-status)\"}"

    echo "[$STATUS],"

    sleep 1
done
