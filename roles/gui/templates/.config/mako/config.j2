max-history=999
sort=-time

on-notify=exec pw-play ~/.local/share/sounds/push.wav
on-button-middle=exec makoctl list -j | jq --raw ".[] | select(.id == $id) | .body" | wl-copy

# TODO: $FONT
font=IBM Plex Mono 13
background-color=#{{ themes[theme].C0_BLACK }}
text-color=#{{ themes[theme].CF_WHITE_BR }}
# TODO: calculate
width=350
# TODO: calculate
height=700
outer-margin=0
margin=10
padding=5
border-size=1
border-color=#{{ themes[theme].CF_WHITE_BR }}
border-radius= 0

ignore-timeout=1

max-visible=5

[urgency=low]
text-color=#{{ themes[theme].C7_WHITE }}
border-color=#{{ themes[theme].C7_WHITE }}

[urgency=high]
text-color=#{{ themes[theme].C9_RED_BR }}
border-color=#{{ themes[theme].C9_RED_BR }}
