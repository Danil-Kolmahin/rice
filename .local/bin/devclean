#!/usr/bin/env bash
set -euo pipefail

# TODO: rewrite

PATTERNS=("node_modules" ".venv" "venv" "dist" "build")
 
# Build: -name A -o -name B -o ...
name_expr=()
for p in "${PATTERNS[@]}"; do name_expr+=(-o -name "$p"); done
name_expr=("${name_expr[@]:1}") # drop leading -o
 
# -prune stops find from descending into matched dirs
mapfile -t FOUND < <(find "${1:-.}" \( "${name_expr[@]}" \) -prune 2>/dev/null)
 
[[ ${#FOUND[@]} -eq 0 ]] && { echo "Nothing to clean."; exit 0; }
 
echo "Found ${#FOUND[@]} item(s):"
for f in "${FOUND[@]}"; do printf "  %-6s %s\n" "$(du -sh "$f" 2>/dev/null | cut -f1)" "$f"; done
 
read -rp $'\nDelete all? [y/N] ' confirm
[[ ! "$confirm" =~ ^[Yy]$ ]] && { echo "Aborted."; exit 0; }
 
for f in "${FOUND[@]}"; do rm -rf "$f" && echo "  ✓ $f" || echo "  ✗ $f"; done
